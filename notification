#!/bin/bash

# Notification publisher script
# Usage: ./notification <datetime_end>
# Example: ./notification 2026-04-02T09:19:00+07:00
#
# Required environment variables:
#   API_TOKEN - Bearer token for authentication
#
# Optional environment variables:
#   API_URL - API base URL (default: https://teralux.devoutsys.com)
#   ROOM_ID - Room ID (default: 4)

# Check parameters
if [ -z "$1" ]; then
  echo "Usage: $0 <datetime_end>"
  echo "Example: $0 2026-04-02T09:19:00+07:00"
  exit 1
fi

# Check for required credentials
if [ -z "$API_TOKEN" ]; then
  echo "❌ Missing required environment variable: API_TOKEN"
  echo "Set it via: export API_TOKEN='your-token-here'"
  exit 1
fi

DATETIME_END=$1
URL="${API_URL:-https://teralux.devoutsys.com}/api/notification/publish"
TOKEN="Bearer $API_TOKEN"
ROOM_ID="${ROOM_ID:-4}"

# Request
curl -X POST "$URL" \
  -H "accept: application/json" \
  -H "content-type: application/json" \
  -H "authorization: $TOKEN" \
  -d "{
    \"datetime_end\": \"$DATETIME_END\",
    \"interval_time\": 1,
    \"room_id\": \"$ROOM_ID\"
  }"
