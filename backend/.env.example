# =============================================================================
# MQTT Configuration
# =============================================================================
MQTT_BROKER=
MQTT_USERNAME=
MQTT_PASSWORD=
EMQX_AUTH_BASE_URL=
EMQX_AUTH_API_KEY=

# =============================================================================
# SMTP Configuration
# =============================================================================
SMTP_HOST=
SMTP_PORT=
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=

# =============================================================================
# Speech / RAG Configuration
# =============================================================================
# LLM provider: "gemini", "orion", "openai", "groq"
LLM_PROVIDER=
WHISPER_TEMP_DIR=

# ---------------------------------------------------------------------------
# Local Configuration
# ---------------------------------------------------------------------------
WHISPER_LOCAL_MODEL=
LLAMA_LOCAL_MODEL=
MAX_FILE_SIZE_MB=

# ---------------------------------------------------------------------------
# Orion Configuration
# ---------------------------------------------------------------------------
ORION_BASE_URL=
ORION_API_KEY=
ORION_MODEL=
ORION_WHISPER_BASE_URL=

# ---------------------------------------------------------------------------
# Gemini Configuration
# ---------------------------------------------------------------------------
GEMINI_API_KEY=
GEMINI_MODEL_HIGH=
GEMINI_MODEL_LOW=
GEMINI_MODEL_WHISPER=

# ---------------------------------------------------------------------------
# OpenAI Configuration
# ---------------------------------------------------------------------------
OPENAI_API_KEY=
OPENAI_MODEL_HIGH=
OPENAI_MODEL_LOW=
OPENAI_MODEL_WHISPER=

# ---------------------------------------------------------------------------
# Groq Configuration
# ---------------------------------------------------------------------------
GROQ_API_KEY=
GROQ_MODEL_HIGH=
GROQ_MODEL_LOW=
GROQ_MODEL_WHISPER=

# =============================================================================
# Chunk Upload & Async Tasks (Go Duration Format: 8h, 30m, 12h)
# =============================================================================
ENABLE_CHUNK_UPLOAD=
CHUNK_UPLOAD_DEFAULT_CHUNK_MB=
CHUNK_UPLOAD_MIN_CHUNK_MB=
CHUNK_UPLOAD_MAX_CHUNK_MB=
CHUNK_UPLOAD_MAX_FILE_SIZE_GB=
CHUNK_UPLOAD_SESSION_TTL=
CHUNK_UPLOAD_CLEANUP_INTERVAL=
TRANSCRIBE_ASYNC_TIMEOUT=
PIPELINE_ASYNC_TIMEOUT=
TASK_STATUS_TTL=

# =============================================================================
# Audio Segmentation & Pipeline Config
# =============================================================================
AUDIO_SEGMENT_ENABLED=
AUDIO_SEGMENT_SEC=
AUDIO_SEGMENT_OVERLAP_SEC=
AUDIO_SEGMENT_MAX_CONCURRENCY=
TASK_EVENT_PUBLISH_ENABLED=

# =============================================================================
# Application Environment
# =============================================================================
APPLICATION_ENVIRONMENT=

# =============================================================================
# API Testing & Swagger Configuration (Optional - for development)
# =============================================================================
# These variables can be used for API testing in Swagger UI or Postman
# They provide default values for authentication and testing

# Default API Key for testing (used in X-API-KEY header)
# This should match the API_KEY value above
TEST_API_KEY=${API_KEY}

# Default JWT Token for testing (used in Authorization: Bearer header)
# Generate a valid JWT token or use a test token during development
TEST_JWT_TOKEN=

# Default Tuya Access Token for testing Tuya endpoints
# Get this from /api/tuya/auth response or use a valid token
TEST_TUYA_ACCESS_TOKEN=

# Default Terminal MAC Address for testing
# Use a real terminal MAC address or a test value
TEST_TERMINAL_MAC=

# Default Terminal ID for testing
# Get this from /api/terminal response after creating a terminal
TEST_TERMINAL_ID=

# Default Device ID for testing
# Get this from /api/devices response after creating a device
TEST_DEVICE_ID=

# Default Scene ID for testing
# Get this from /api/terminal/:id/scenes response after creating a scene
TEST_SCENE_ID=

# Default Recording ID for testing
# Get this from /api/recordings response after creating a recording
TEST_RECORDING_ID=

# Default Email for testing mail endpoints
TEST_EMAIL=

# Swagger UI Configuration
# Enable/disable Swagger UI (default: true in development)
SWAGGER_ENABLED=true
