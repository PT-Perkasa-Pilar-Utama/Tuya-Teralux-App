# FastAPI Settings
PORT=8000
HOST=0.0.0.0
DEBUG=true

# Security
JWT_SECRET=your-shared-jwt-secret-here
JWT_ALGORITHM=HS256

# Milvus Settings
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_COLLECTION=rag_docs

# API Keys (set these in your local .env)
OPENAI_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=
ORION_API_KEY=

# Default Models
DEFAULT_LLM_MODEL=openai/gpt-4o
DEFAULT_EMBEDDING_MODEL=openai/text-embedding-3-small
DEFAULT_WHISPER_MODEL=openai/whisper-1
